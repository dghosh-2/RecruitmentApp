# ============================================================
# RecruiterPro Updated — environment configuration
# Copy this file to .env and fill in values as needed. Only
# OPENAI_API_KEY is required for AI-powered discovery and
# extraction; everything else works out of the box locally.
# ============================================================

# --- OpenAI (required for careers-page discovery + AI extraction) ---
OPENAI_API_KEY=sk-REPLACE_ME
# Model used for structured listing extraction and web-search discovery
OPENAI_MODEL=gpt-4o

# --- Backend ---
NODE_ENV=development
PORT=4000
# SQLite file path, relative to backend/ (auto-created on first boot)
DATABASE_PATH=data/recruiterpro.db
JWT_SECRET=dev-only-secret-replace-with-long-random-string
JWT_EXPIRES_IN=7d

# --- Scraping behavior ---
# Max pages to follow on paginated career sites (page=1,2,3...)
# Each page costs one OpenAI call; large boards (e.g. SIG) span 20+ pages.
SCRAPE_MAX_PAGES=30
# Per-page navigation timeout for Playwright
SCRAPE_TIMEOUT_MS=30000
# How many companies scrape concurrently during "Scrape all"
SCRAPE_CONCURRENCY=2

# --- Email (future seam — console provider used when no key set) ---
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=RecruiterPro <noreply@example.com>

# --- Frontend ---
APP_URL=http://localhost:5173
